{
  "theme": "Default",
  "checkpointing": true,
  "mcpServers": {
    "serena": {
      "command": "/opt/homebrew/bin/uv",
      "args": [
        "run",
        "--directory",
        "${SERENA_ROOT}",
        "serena-mcp-server",
        "--transport",
        "stdio",
        "--host",
        "127.0.0.1",
        "--port",
        "9121",
        "--context",
        "ide-assistant",
        "--project",
        "${PROJECT_ROOT}"
      ]
    }
  }}
