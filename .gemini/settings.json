{
  "general": {
    "previewFeatures": true
  },
  "mcpServers": {
    "laravel-boost": {
      "command": "/bin/sh",
      "args": [
        "-c",
        "cd /Users/kazutaka/PhpstormProjects/LedgerLeap && vendor/bin/sail artisan boost:mcp"
      ]
    },
    "ledgerleap-api": {
      "command": "/bin/sh",
      "args": [
        "-c",
        "cd /Users/kazutaka/PhpstormProjects/LedgerLeap && vendor/bin/sail artisan mcp:start ledgerleap:mcp"
      ]
    },
    "serena": {
      "command": "/opt/homebrew/bin/uv",
      "args": [
        "run",
        "--directory",
        "/Users/kazutaka/serena",
        "serena-mcp-server",
        "--transport",
        "stdio",
        "--host",
        "127.0.0.1",
        "--port",
        "9121",
        "--project",
        "PROJECT_ROOT"
      ],
      "env": {
        "SERENA_ROOT": "${SERENA_ROOT}",
        "PROJECT_ROOT": "${PROJECT_ROOT}"
      }
    },
  "ui": {
    "theme": "Default"
  }
}