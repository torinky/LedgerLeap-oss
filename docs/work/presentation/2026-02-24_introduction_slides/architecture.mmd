%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#0f172a', 'edgeLabelBackground':'#fff', 'tertiaryColor': '#fff'}}}%%
graph TD
    subgraph UserSide [👤 利用者]
        Users("社員・管理者<br>PC・スマホ・タブレットから利用")
    end

    subgraph LedgerLeap [🏢 LedgerLeap プラットフォーム]
        direction TB

        subgraph Core [業務アプリケーション]
            App("台帳の登録・閲覧・承認<br>権限管理・ワークフロー")
            Async("📬 バックグラウンド処理<br>ファイルの解析を自動実行")
        end

        subgraph Storage [💾 データベース（MySQL）]
            direction LR
            DB[("台帳データ・権限・履歴<br>等すべてのデータを保存")]
            Search[("🔍 日本語全文検索エンジン<br>キーワードで即座に検索<br>同義語も自動展開")]
        end

        subgraph AI [🤖 書類 AI 解析エンジン（自動・非同期）]
            direction LR
            Extract("PDF・Word・Excel<br>からテキスト抽出")
            Vision("画像・スキャン書類<br>から文字認識（AI-OCR）")
        end
    end

    subgraph External [🔗 外部連携]
        LLM("生成 AI<br>（Claude 等）")
        API("API・MCP<br>他システム連携")
    end

    %% メインフロー
    Users ==>|ブラウザでアクセス| App
    App <==>|データ保存・読込| DB
    App -->|キーワード検索| Search
    DB -.-|書き込み時に自動でインデックス更新| Search

    %% 添付ファイル → AI → 検索可能に
    App -->|ファイル添付時に自動起動| Async
    Async --> Extract
    Async --> Vision
    Extract -->|抽出テキストをデータベースに保存| DB
    Vision -->|認識テキストをデータベースに保存| DB

    %% 外部連携
    App <-->|台帳操作・データ取得| API
    API <-->|AI による要約・検索補助| LLM

    %% Styling
    classDef user fill:#3b82f6,color:#fff,stroke:#2563eb,stroke-width:2px;
    classDef app fill:#e0e7ff,color:#3730a3,stroke:#6366f1,stroke-width:2px;
    classDef db fill:#0f4c3a,color:#fff,stroke:#34d399,stroke-width:2px;
    classDef search fill:#06b6d4,color:#fff,stroke:#0891b2,stroke-width:2px;
    classDef ai fill:#fff7ed,color:#92400e,stroke:#f59e0b,stroke-width:2px;
    classDef ext fill:#f3f4f6,color:#374151,stroke:#9ca3af,stroke-width:1px;

    class Users user;
    class App,Async app;
    class DB db;
    class Search search;
    class Extract,Vision ai;
    class LLM,API ext;
