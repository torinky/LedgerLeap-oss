APP_NAME=LedgerLeap
APP_SERVICE=laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

WWWUSER=1000
WWWGROUP=1000

DOCKER_GROUP_ID=0

DB_CONNECTION=mysql
#DB_CONNECTION=wordnet
#DB_CONNECTION=tansi
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ledgerleap
DB_USERNAME=sail
DB_PASSWORD=password

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# MCP Server Authentication
MCP_AUTH_TOKEN=

# Scoring System Configuration
SCORING_SCHEDULE_FREQUENCY=daily

# AutoLink Base URL (パスベーステナント用)
AUTO_LINK_BASE_URL=http://localhost

# RAG (Retrieval-Augmented Generation) Settings
RAG_ENABLED=true
EMBEDDING_SERVICE_URL=http://embedding:8000
EMBEDDING_SERVICE_TIMEOUT=180
RAG_MODEL=bge-m3
RAG_CHUNK_SIZE=2000
RAG_CHUNK_OVERLAP=400
RAG_USE_ONNX=true
RAG_ONNX_OPT_LEVEL=all
RAG_INTRA_OP_THREADS=0
RAG_INTER_OP_THREADS=0
RAG_EXECUTION_MODE=sequential
RAG_QUANTIZE=false
RAG_BATCH_SIZE=1
RAG_NUM_THREADS=0
RAG_NUM_INTEROP_THREADS=0
RAG_CONVERT_TO_NUMPY=true
RAG_DEVICE=cpu

# VLM (Visual Language Model) Service Configuration
# ================================================

# VLM Model Selection
# Specifies which OCR/Document parsing model to use
# Options:
#   - paddleocr       : PaddleOCR 2.7.3 (stable, tested, production-ready)
#   - paddleocr-vl    : PaddleOCR-VL 0.9B (experimental, world #1 performance)
#   - marker          : Marker (PDF to Markdown converter)
VLM_MODEL=paddleocr

# Docker build context (set based on VLM_MODEL)
# For paddleocr: use ./docker/paddle
# For paddleocr-vl: use ./docker/paddleocr-vl
# For marker: use ./docker/marker
VLM_SERVICE_CONTEXT=./docker/paddle

# VLM Service Port Configuration
VLM_SERVICE_PORT=8001

# Internal port (differs by model)
# paddleocr: 8000, paddleocr-vl: 8002, marker: 8000
VLM_INTERNAL_PORT=8000

# ================================================
# Quick Setup Examples:
# ================================================
#
# To use PaddleOCR 2.7.3 (stable):
#   VLM_MODEL=paddleocr
#   VLM_SERVICE_CONTEXT=./docker/paddle
#   VLM_INTERNAL_PORT=8000
#
# To use PaddleOCR-VL 0.9B (experimental):
#   VLM_MODEL=paddleocr-vl
#   VLM_SERVICE_CONTEXT=./docker/paddleocr-vl
#   VLM_INTERNAL_PORT=8002
#
# To use Marker (PDF to Markdown):
#   VLM_MODEL=marker
#   VLM_SERVICE_CONTEXT=./docker/marker
#   VLM_INTERNAL_PORT=8000
# ================================================

