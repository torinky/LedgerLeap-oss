{
  "mcpServers": {
    "laravel-boost": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "ledgerleap-laravel-1",
        "php",
        "artisan",
        "boost:mcp"
      ]
    },
    "ledgerleap-api": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "ledgerleap-laravel-1",
        "php",
        "artisan",
        "mcp:start",
        "ledgerleap:mcp"
      ]
    },
    "serena": {
      "command": "/opt/homebrew/bin/uv",
      "args": [
        "run",
        "--directory",
        "../../serena",
        "serena-mcp-server",
        "--transport",
        "stdio",
        "--host",
        "127.0.0.1",
        "--port",
        "9121",
        "--project",
        "PROJECT_ROOT"
      ],
      "env": {
        "SERENA_ROOT": "${SERENA_ROOT}",
        "PROJECT_ROOT": "${PROJECT_ROOT}"
      }
    }
  }
}