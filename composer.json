{
  "name": "laravel/laravel",
  "type": "project",
  "description": "The Laravel Framework.",
  "keywords": [
    "framework",
    "laravel"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "ext-bcmath": "*",
    "ext-curl": "*",
    "ext-dom": "*",
    "ext-fileinfo": "*",
    "ext-gd": "*",
    "ext-intl": "*",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "15web/filament-tree": "*",
    "althinect/filament-spatie-roles-permissions": "^2",
    "codewithdennis/filament-select-tree": "^3",
    "darkaonline/l5-swagger": "^9.0",
    "directorytree/ldaprecord-laravel": "^3.4",
    "filament/filament": "^3",
    "guzzlehttp/guzzle": "^7",
    "intervention/image": "^2",
    "kalnoy/nestedset": "^6",
    "laravel/framework": "^12",
    "laravel/mcp": "^0.3",
    "laravel/sanctum": "^4",
    "laravel/tinker": "^2",
    "livewire/livewire": "^3",
    "livewire/volt": "^1",
    "logue/igo-php": "^0.2",
    "maatwebsite/excel": "^3",
    "predis/predis": "^3.0",
    "robsontenorio/mary": "^2",
    "sebastian/diff": "^6.0",
    "simplesoftwareio/simple-qrcode": "^4.2",
    "spatie/laravel-activitylog": "^4",
    "spatie/laravel-markdown": "^2.7",
    "spatie/laravel-permission": "^6",
    "spatie/laravel-query-builder": "^6",
    "stancl/tenancy": "^3",
    "vaites/php-apache-tika": "^1"
  },
  "require-dev": {
    "ext-json": "*",
    "barryvdh/laravel-debugbar": "^3",
    "barryvdh/laravel-ide-helper": "^3",
    "bottelet/translation-checker": "^1",
    "cweagans/composer-patches": "^2.0",
    "fakerphp/faker": "^1",
    "laravel-lang/attributes": "^2",
    "laravel-lang/common": "*",
    "laravel/boost": "^1.8",
    "laravel/breeze": "^2",
    "laravel/pint": "^1",
    "laravel/sail": "*",
    "mockery/mockery": "^1",
    "nunomaduro/collision": "^8",
    "pestphp/pest": "^3",
    "pestphp/pest-plugin-laravel": "^3.2",
    "phpunit/phpunit": "^11",
    "roave/security-advisories": "dev-latest",
    "spatie/laravel-ignition": "^2",
    "squizlabs/php_codesniffer": "3.*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi",
      "@php artisan ide-helper:generate",
      "@php artisan filament:upgrade"
    ],
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
      "@php artisan lang:update",
      "@php artisan translations:compare --force"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    },
    "patches": {
      "laravel/boost": {
        "Fix MCP tools schema": "patches/fix_mcp_tools_schema.patch"
      },
      "laravel/mcp": {
        "Fix MCP server protocol versions": "patches/fix_mcp_server_protocol_versions.patch"
      },
      "stancl/tenancy": {
        "PHP 8.4 compatibility - Fix deprecated trait static property access": "patches/fix_tenancy_php84_trait_property.patch"
      }
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-http/discovery": true,
      "cweagans/composer-patches": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
