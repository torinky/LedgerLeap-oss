{
  "name": "laravel/laravel",
  "type": "project",
  "description": "The Laravel Framework.",
  "keywords": [
    "framework",
    "laravel"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "ext-bcmath": "*",
    "ext-curl": "*",
    "ext-dom": "*",
    "ext-fileinfo": "*",
    "ext-gd": "*",
    "ext-intl": "*",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "15web/filament-tree": "*",
    "althinect/filament-spatie-roles-permissions": "^2",
    "codewithdennis/filament-select-tree": "^3",
    "darkaonline/l5-swagger": "^9.0",
    "directorytree/ldaprecord-laravel": "^3.4",
    "filament/filament": "^3",
    "guzzlehttp/guzzle": "^7",
    "intervention/image": "^2",
    "kalnoy/nestedset": "^6",
    "laravel/framework": "^12",
    "laravel/mcp": "^0.5",
    "laravel/sanctum": "^4",
    "laravel/tinker": "^2",
    "livewire/livewire": "^3",
    "livewire/volt": "^1",
    "logue/igo-php": "^0.2",
    "maatwebsite/excel": "^3",
    "predis/predis": "^3.0",
    "robsontenorio/mary": "^2",
    "sebastian/diff": "^6.0",
    "simplesoftwareio/simple-qrcode": "^4.2",
    "spatie/laravel-activitylog": "^4",
    "spatie/laravel-markdown": "^2.7",
    "spatie/laravel-permission": "^6",
    "spatie/laravel-query-builder": "^6",
    "stancl/tenancy": "^3",
    "vaites/php-apache-tika": "^1"
  },
  "require-dev": {
    "ext-json": "*",
    "barryvdh/laravel-debugbar": "^3",
    "barryvdh/laravel-ide-helper": "^3",
    "bottelet/translation-checker": "^1",
    "cweagans/composer-patches": "^2.0",
    "fakerphp/faker": "^1",
    "infection/infection": "^0.32.4",
    "laravel-lang/attributes": "^2",
    "laravel-lang/common": "*",
    "laravel/boost": "^1.8",
    "laravel/breeze": "^2",
    "laravel/pint": "^1",
    "laravel/sail": "*",
    "mockery/mockery": "^1",
    "nunomaduro/collision": "^8",
    "pestphp/pest": "^3",
    "pestphp/pest-plugin-laravel": "^3.2",
    "phpunit/phpunit": "^11",
    "roave/security-advisories": "dev-latest",
    "spatie/laravel-ignition": "^2",
    "squizlabs/php_codesniffer": "3.*",
    "systemsdk/phpcpd": "^8.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi",
      "@php artisan ide-helper:generate",
      "@php artisan filament:upgrade"
    ],
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
      "@php artisan lang:update",
      "@php artisan translations:compare --force"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi"
    ],
    "test:prepare:local": "bash ./bin/prepare-local-test-env.sh",
    "test:full": [
      "@test:prepare:local",
      "@test:ci:unit",
      "@test:ci:feature",
      "@test:ci:db-migrations",
      "@test:external"
    ],
    "test:ci:unit": "vendor/bin/pest --testsuite=Unit --exclude-group=external --exclude-group=database-migrations --display-errors",
    "test:ci:feature": "vendor/bin/pest --testsuite=Feature --exclude-group=external --exclude-group=database-migrations --display-errors",
    "test:ci:db-migrations": "vendor/bin/pest --group=database-migrations --display-errors",
    "test:external": "vendor/bin/pest --group=external --display-errors",
    "test:canary:unit": "vendor/bin/pest --parallel --configuration phpunit.parallel.xml --testsuite=Unit --exclude-group=external --exclude-group=database-migrations --display-errors",
    "test:canary:feature": "vendor/bin/pest --parallel --configuration phpunit.parallel.xml --testsuite=FeatureParallelSubset --exclude-group=external --exclude-group=database-migrations --display-errors",
    "test:coverage": [
      "@test:prepare:local",
      "vendor/bin/pest --coverage-html coverage"
    ],
    "test:coverage:unit": "php -d pcov.enabled=1 vendor/bin/pest --testsuite=Unit --exclude-group=external --exclude-group=database-migrations --coverage-html coverage/unit",
    "test:coverage:unit:parallel": "php -d pcov.enabled=1 vendor/bin/pest --parallel --configuration phpunit.parallel.xml --testsuite=Unit --exclude-group=external --exclude-group=database-migrations --coverage-html coverage/unit-parallel",
    "test:coverage:feature-subset:parallel": "php -d pcov.enabled=1 vendor/bin/pest --parallel --configuration phpunit.parallel.xml --testsuite=FeatureParallelSubset --exclude-group=external --exclude-group=database-migrations --coverage-html coverage/feature-subset-parallel",
    "test:duplication": "vendor/bin/phpcpd app",
    "test:mutation": "vendor/bin/infection"
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    },
    "patches": {
      "laravel/boost": {
        "Fix MCP tools schema for Laravel 12": "patches/fix_mcp_tools_schema.patch"
      },
      "althinect/filament-spatie-roles-permissions": {
        "Fix Filament 3 type compatibility for getNavigationGroup()": "patches/fix_filament_spatie_roles_permissions.patch"
      },
      "stancl/tenancy": {
        "Fix PHP 8.4 static trait property deprecation": "patches/fix_tenancy_php84_trait_property.patch"
      }
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "cweagans/composer-patches": true,
      "infection/extension-installer": true,
      "pestphp/pest-plugin": true,
      "php-http/discovery": true
    },
    "process-timeout": 8000
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}