{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ext-mbstring": "*",
        "althinect/filament-spatie-roles-permissions": "^2.2",
        "codewithdennis/filament-select-tree": "^3.1",
        "cube-agency/filament-tree-view": "^1.0",
        "filament/filament": "^3.2",
        "guzzlehttp/guzzle": "^7.2",
        "intervention/image": "^2.7",
        "kalnoy/nestedset": "^6.0",
        "laravel/framework": "^11",
        "laravel/sanctum": "^4",
        "laravel/tinker": "^2.8",
        "livewire/livewire": "^3.5",
        "logue/igo-php": "^0.2.1",
        "maatwebsite/excel": "^3.1.48",
        "robsontenorio/mary": "^1.35",
        "sebastian/diff": "^6.0",
        "spatie/laravel-activitylog": "^4.9",
        "spatie/laravel-markdown": "^2.7",
        "spatie/laravel-permission": "^6.9",
        "vaites/php-apache-tika": "^1.3"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.8",
        "barryvdh/laravel-ide-helper": "^3",
        "bottelet/translation-checker": "^1.1",
        "fakerphp/faker": "^1.9.1",
        "laravel-lang/attributes": "^2.7",
        "laravel-lang/common": "*",
        "laravel/breeze": "^2",
        "laravel/pint": "^1.0",
        "laravel/sail": "*",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11",
        "roave/security-advisories": "dev-latest",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan ide-helper:generate",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan lang:update"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
