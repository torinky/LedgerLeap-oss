{
  "$schema": "https://opencode.ai/config.json",
  "model": "kimi-latest",
  "instructions": [
    "AGENTS.md",
    ".github/copilot-instructions.md",
    ".github/instructions/*.instructions.md"
  ],
  "watcher": {
    "ignore": [
      "node_modules/**",
      "vendor/**",
      "storage/**",
      "bootstrap/cache/**",
      ".git/**",
      "coverage/**",
      ".venv/**",
      ".idea/**",
      ".serena/**"
    ]
  },
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "skill": {
      "*": "allow",
      "doc-*": "allow"
    }
  },
  "share": "manual",
  "autoupdate": "notify",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "snapshot": true,
}
