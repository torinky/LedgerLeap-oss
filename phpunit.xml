<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="./vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory suffix="Test.php">./tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory suffix="Test.php">./tests/Feature</directory>
        </testsuite>
        <testsuite name="FeatureParallelSubset">
            <directory suffix="Test.php">./tests/Feature/Livewire</directory>
            <directory suffix="Test.php">./tests/Feature/Services</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory suffix=".php">./app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="LOG_CHANNEL" value="single"/>
        <!-- テスト専用のMySQL接続を使用 -->
        <server name="DB_CONNECTION" value="mysql_testing"/>
        <server name="DB_DATABASE" value="ledgerleap_test"/>
        <env name="BCRYPT_ROUNDS" value="10"/>
        <env name="CACHE_DRIVER" value="array"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <!-- RAGジョブを標準では自動実行しない。外部 Embedding コンテナが不要なテストで -->
        <!-- Queue::fake() なしに QUEUE_CONNECTION=sync が LedgerObserver を通じて      -->
        <!-- EmbeddingService に接続を試みて 60 秒タイムアウトを引き起こすのを防ぐ。      -->
        <!-- RAG 機能を必要とするテストは setUp() で config(['rag.enabled' => true]) を設定する。 -->
        <env name="RAG_ENABLED" value="false"/>

        <!-- LDAP Testing Configuration -->
        <env name="LDAP_LOGGING" value="true"/>
        <env name="LDAP_HOST" value="openldap"/>
        <env name="LDAP_USERNAME" value="cn=admin,dc=planetexpress,dc=com"/>
        <env name="LDAP_PASSWORD" value="GoodNewsEveryone"/>
        <env name="LDAP_PORT" value="10389"/>
        <env name="LDAP_BASE_DN" value="dc=planetexpress,dc=com"/>
    </php>
</phpunit>
